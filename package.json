    "@types/node": "^18",
    "@types/react": "^18",
    "@types/semver": "^7.5.8",
    "@visx/visx": "^3.12.0",
    "ahooks": "^3.9.6",
    "antd": "^6.3.0",
    "date-fns": "^4.1.0",
    "effect": "^3.19.19",
    "lefthook": "^1.6.16",
    "lodash-es": "^4.17.23",
    "next": "16.0.0",
    "outline": "link:@heroicons/react/24/outline",
    "pathe": "^2.0.3",
    "pkg-pr-new": "^0.0.63",
    "ramda": "^0.32.0",
    "react": "19.2.0",
