    "react-icons": "^5.5.0",
    "react-use": "^17.6.0",
    "recharts": "^3.7.0",
    "rollup": "^4.18.0",
    "rxjs": "^7.8.2",
    "semver": "^7.6.3",
    "storybook": "^9.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@next/env": "16.0.0",
    "exsolve": "^1.0.8",
    "image-size": "^2.0.0",
    "magic-string": "^0.30.11",
    "module-alias": "^2.2.3",
    "oxc-transform": "^0.115.0",
    "ts-dedent": "^2.2.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "vite-plugin-storybook-nextjs": "workspace:*",
      "next": "^16.0.0"
    }
  }
}